{
  "name": "claude-report",
  "version": "0.1.8",
  "description": "Automatic dev status updates from Claude Code to Slack",
  "type": "module",
  "bin": {
    "claude-report": "./dist/cli/index.js"
  },
  "main": "./dist/core/index.js",
  "types": "./dist/core/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./mcp": {
      "types": "./dist/mcp/server.d.ts",
      "import": "./dist/mcp/server.js"
    }
  },
  "files": [
    "dist",
    ".claude-plugin",
    ".mcp.json",
    "skills",
    "claude-md-snippet.md",
    "slack-app-manifest.json",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "claude --plugin-dir .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "claude-code",
    "claude-code-plugin",
    "mcp",
    "slack",
    "status",
    "team",
    "developer-tools"
  ],
  "author": "Yuya Morita",
  "repository": {
    "type": "git",
    "url": "https://github.com/knorq-ai/claude-report.git"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@slack/web-api": "^7.9.1",
    "commander": "^13.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1",
    "@types/node": "^22.14.1"
  }
}
